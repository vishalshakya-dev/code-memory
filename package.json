{
  "name": "context-os",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first CLI that generates deterministic AI-readable context for codebases.",
  "keywords": [
    "ai",
    "code-context",
    "developer-tools",
    "cli",
    "static-analysis",
    "monorepo"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/code-memory/code-memory.git"
  },
  "homepage": "https://github.com/code-memory/code-memory#readme",
  "bugs": {
    "url": "https://github.com/code-memory/code-memory/issues"
  },
  "author": "CodeMemory Contributors",
  "license": "MIT",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter code-memory-cli dev",
    "release:verify": "pnpm install && pnpm build && pnpm test && pnpm typecheck",
    "release:pack": "npm pack ./packages/core && npm pack ./packages/cli",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.15.17",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
